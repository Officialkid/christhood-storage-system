# ══════════════════════════════════════════════════════════════════════════════
# Christhood CMMS — Environment Variables
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every value below — nothing ships with real secrets.
# 3. NEVER commit .env to git — it is already in .gitignore.
# ══════════════════════════════════════════════════════════════════════════════


# ── PostgreSQL (consumed by the "db" Docker Compose service) ──────────────────

# Username created for the PostgreSQL superuser on first boot
POSTGRES_USER=christhood

# Password for that superuser — use a long random string in production
POSTGRES_PASSWORD=change_me_in_production

# Name of the database created on first boot
POSTGRES_DB=christhood_cmms


# ── Prisma / Application Database URL ─────────────────────────────────────────
#
# DOCKER COMPOSE: hostname MUST be "db" (the Compose service name).
#   DATABASE_URL=postgresql://christhood:change_me_in_production@db:5432/christhood_cmms
#
# LOCAL DEV (npm run dev against a local Postgres): replace "db" with "localhost".
#   DATABASE_URL=postgresql://christhood:change_me_in_production@localhost:5432/christhood_cmms
#
DATABASE_URL=postgresql://christhood:change_me_in_production@db:5432/christhood_cmms


# ── NextAuth.js ───────────────────────────────────────────────────────────────

# Secret used to sign session cookies and JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_32_byte_random_string

# The canonical public URL of the Next.js app — no trailing slash.
# NextAuth uses this to build callback URLs.
NEXTAUTH_URL=http://localhost:3000


# ── Cloudflare R2 Object Storage ─────────────────────────────────────────────

# Found in: Cloudflare dashboard → R2 → Overview → Account ID
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 API token Access Key ID (created under Manage R2 API Tokens)
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id

# R2 API token Secret Access Key (shown only once at creation time)
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Name of the R2 bucket where media files are stored
CLOUDFLARE_R2_BUCKET_NAME=christhood-media

# Public CDN base URL — set only if your bucket has a custom public domain
# CLOUDFLARE_R2_PUBLIC_URL=https://media.christhood.org

# R2 S3-compatible endpoint — constructed automatically from the account ID.
# Only override this if you are using a custom endpoint or a different provider.
# Default used in code: https://<CLOUDFLARE_R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com


# ── Resend (transactional email) ──────────────────────────────────────────────

# API key from resend.com → API Keys.
# Free tier: 3 000 emails/month, 100/day.
RESEND_API_KEY=re_your_resend_api_key

# The "From" address for all outgoing emails.
# Must be a verified sender domain in your Resend account.
# For testing you can use: onboarding@resend.dev
FROM_EMAIL=noreply@yourdomain.com


# ── Web Push Notifications (VAPID) ───────────────────────────────────────────
#
# Generate a key pair ONCE with:
#   npx web-push generate-vapid-keys
#
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is sent to browsers — safe to be public.
# VAPID_PUBLIC_KEY is the server-side name used by lib/webpush.ts.
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Contact shown to push services (must be mailto: or https:)
VAPID_SUBJECT=mailto:admin@yourdomain.com


# ── Public app URL ────────────────────────────────────────────────────────────
#
# Used wherever the app needs to construct absolute URLs
# (email links, push notification click actions, OG meta tags, etc.).
# Must match NEXTAUTH_URL in most deployments.
#
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Google OAuth (optional) ───────────────────────────────────────────────────
#
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
#
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret


# ── Miscellaneous ─────────────────────────────────────────────────────────────

# Percentage of total storage at which to send a storage-alert email (default 80)
STORAGE_THRESHOLD_PERCENT=80

# Total storage budget in GB used to compute the percentage above (default 50)
STORAGE_LIMIT_GB=50


# ── Automation thresholds (optional — safe defaults are used if omitted) ──────

# How many months after a file is created before it is automatically archived.
# Archiving is reversible — the file is hidden from the default view and marked
# ARCHIVED but no data is deleted.
# Default: 6
ARCHIVE_THRESHOLD_MONTHS=6

# How many days a file stays in the Trash before being permanently purged
# (R2 object deleted + DB record marked PURGED). This cannot be undone.
# Default: 30
TRASH_RETENTION_DAYS=30


# ── Automation thresholds (optional — safe defaults are used if omitted) ───────────

# How many months after a file is created before it is automatically archived.
# Archiving is reversible — no data is deleted, the file is just hidden from
# the default library view and marked ARCHIVED.
# Default: 6
ARCHIVE_THRESHOLD_MONTHS=6

# How many days a file stays in the Trash before being permanently purged
# (R2 object deleted + DB record marked PURGED). This cannot be undone.
# Default: 30
TRASH_RETENTION_DAYS=30
