# ─────────────────────────────────────────────────────────────
# Christhood CMMS — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/christhood_cmms?sslmode=prefer"

# Cloudflare R2 — find these in the Cloudflare dashboard under R2 → Manage API Tokens
CLOUDFLARE_R2_ACCOUNT_ID="your_account_id_here"
CLOUDFLARE_R2_ACCESS_KEY_ID="your_access_key_id_here"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your_secret_access_key_here"
CLOUDFLARE_R2_BUCKET_NAME="christhood-media"

# Public CDN base URL (optional) — set if your R2 bucket has a custom domain or public URL
# CLOUDFLARE_R2_PUBLIC_URL="https://media.christhood.org"

# NextAuth
# Generate with: openssl rand -base64 32   or   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="replace_with_a_strong_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# Cron purge job — set a strong secret and pass it as Bearer token when calling /api/cron/purge
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="replace_with_a_strong_random_secret"

# ─────────────────────────────────────────────────────────────
# Transactional Email — Resend (https://resend.com)
# ─────────────────────────────────────────────────────────────
# Create a free account at resend.com, verify your domain, and generate an API key.
# Free tier: 3,000 emails/month, 100/day.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The "From" address for all outgoing emails.
# Must be a verified sender on your Resend account (or use onboarding@resend.dev for testing).
FROM_EMAIL="noreply@christhood.org"

# ─────────────────────────────────────────────────────────────
# Web Push Notifications (VAPID — https://www.rfc-editor.org/rfc/rfc8030)
# Generate once with: node scripts/generate-vapid-keys.mjs
# ─────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY="generate_with_scripts/generate-vapid-keys.mjs"
VAPID_PRIVATE_KEY="generate_with_scripts/generate-vapid-keys.mjs"
# mailto: address shown to push services as the push contact
VAPID_SUBJECT="mailto:admin@christhood.org"

# ─────────────────────────────────────────────────────────────
# Storage threshold alert (used by /api/cron/storage-check)
# ─────────────────────────────────────────────────────────────
# Percentage at which to fire the storage alert email (default: 80)
STORAGE_THRESHOLD_PERCENT="80"
# Total storage limit in GB (default: 50)
STORAGE_LIMIT_GB="50"
