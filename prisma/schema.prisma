// Christhood CMMS — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  UPLOADER
  EDITOR
}

enum FileType {
  PHOTO
  VIDEO
}

enum FileStatus {
  RAW
  EDITING_IN_PROGRESS
  EDITED
  PUBLISHED
  ARCHIVED
  DELETED /// soft-deleted — file is in Trash, R2 object still exists
  PURGED /// permanently removed from R2 after 30-day window expired
}

enum TransferStatus {
  PENDING /// sent — recipient has not downloaded yet
  DOWNLOADED /// recipient has downloaded the files
  RESPONDED /// recipient has uploaded edited files back
  COMPLETED /// admin has downloaded the response and marked complete
  EXPIRED /// auto-purged after expiry date
}

enum MessagePriority {
  NORMAL /// standard notification — blue badge
  URGENT /// red badge + immediate email regardless of user preferences
}

enum GalleryStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
  DELETED
  PURGED
}

enum GalleryFileType {
  PHOTO
  VIDEO
}

// ─────────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────────

model User {
  id                     String   @id @default(cuid())
  username               String?  @unique /// nullable for OAuth-created accounts
  email                  String   @unique
  passwordHash           String? /// null for OAuth-only accounts
  phone                  String?
  role                   Role     @default(UPLOADER)
  hasCompletedOnboarding Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Optional fields required by @next-auth/prisma-adapter
  name          String?
  emailVerified DateTime?
  image         String?

  // Relations
  accounts          Account[]
  sessions          Session[]
  uploads           MediaFile[]              @relation("uploader")
  fileVersions      FileVersion[]
  activityLogs      ActivityLog[]
  trashedItems      TrashItem[]
  resetTokens       PasswordResetToken[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  notificationPrefs NotificationPreference[]
  folderFollows     FolderFollow[]

  // File Transfer relations
  sentTransfers     Transfer[]         @relation("sender")
  receivedTransfers Transfer[]         @relation("recipient")
  transferResponses TransferResponse[] @relation("responseUploader")

  // Internal messaging relations
  sentMessages      Message[]          @relation("messageSender")
  messageRecipients MessageRecipient[] @relation("messageRecipient")

  // Email digest frequency — controls when upload digest emails are sent
  /// "IMMEDIATE" | "DAILY" | "WEEKLY" | "NEVER"
  emailDigestFrequency String @default("IMMEDIATE")

  // Brute-force protection (Layer 3 — account lockout)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Zara AI assistant action log — all confirmed actions performed on behalf of this user
  zaraActionLogs ZaraActionLog[]

  // Zara AI assistant usage analytics — one record per chat session
  zaraUsageLogs ZaraUsageLog[]

  // Privacy: when true, no conversation logs are stored for this user
  zaraLoggingOptOut Boolean @default(false)

  // External share links created by this user
  shareLinks ShareLink[]

  // Custom event categories created by this user (via "Other" in create event form)
  createdCategories EventCategory[] @relation("CategoryCreator")

  // Account deactivation
  isActive        Boolean   @default(true)
  deactivatedAt   DateTime?
  deactivatedById String?
  deactivatedBy   User?     @relation("DeactivatedBy", fields: [deactivatedById], references: [id], onDelete: SetNull)
  deactivatedUsers User[]   @relation("DeactivatedBy")

  // Self-initiated account deletion (24-hour grace period)
  pendingDeletionAt     DateTime? // when deletion was requested; null = no pending deletion
  pendingDeletionAction String?   // 'reassign' | 'archive' | 'trash'

  // Gallery relations
  galleriesCreated   PublicGallery[] @relation("GalleryCreatedBy")
  galleriesPublished PublicGallery[] @relation("GalleryPublishedBy")
  galleriesDeleted   PublicGallery[] @relation("GalleryDeletedBy")

  // ── Two-Factor Authentication (TOTP) ─────────────────────────────────────
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String?  // AES-encrypted TOTP secret
  twoFactorBackupCodes String[] // bcrypt-hashed backup codes (each used once)
}

// ─────────────────────────────────────────────
// NextAuth adapter tables
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Year / Event Hierarchy
// ─────────────────────────────────────────────

model Year {
  id        String   @id @default(cuid())
  year      Int      @unique
  createdAt DateTime @default(now())

  categories EventCategory[]
}

/// e.g. Saturday Fellowships, Missions, Branch Excandidates Programme, Teen Life, etc.
model EventCategory {
  id              String   @id @default(cuid())
  name            String
  yearId          String
  isDefault       Boolean  @default(false)   /// true for the 7 official Christhood categories
  isArchived      Boolean  @default(false)   /// archived categories hide from new event creation
  createdByUserId String?                    /// null for official categories, set for custom ones

  year          Year    @relation(fields: [yearId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("CategoryCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  events        Event[]

  @@index([yearId])
  @@index([isArchived])
}

model Event {
  id         String   @id @default(cuid())
  name       String
  date       DateTime
  categoryId String
  createdAt  DateTime @default(now())

  category     EventCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subfolders   EventSubfolder[]
  mediaFiles   MediaFile[]
  activityLogs ActivityLog[]
  tags         Tag[]            @relation("EventTags")
  followers    FolderFollow[]
  galleries    PublicGallery[]
}

/// e.g. Friday, Saturday, Sunday
model EventSubfolder {
  id      String @id @default(cuid())
  label   String
  eventId String

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mediaFiles MediaFile[]
}

// ─────────────────────────────────────────────
// Media
// ─────────────────────────────────────────────

model MediaFile {
  id           String     @id @default(cuid())
  originalName String
  storedName   String
  r2Key        String     @unique
  fileType     FileType
  fileSize     BigInt
  status       FileStatus @default(RAW)
  uploaderId   String
  eventId      String
  subfolderId  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  uploader  User            @relation("uploader", fields: [uploaderId], references: [id])
  event     Event           @relation(fields: [eventId], references: [id])
  subfolder EventSubfolder? @relation(fields: [subfolderId], references: [id])

  thumbnailKey     String? /// R2 key of the generated JPEG thumbnail (null until processed)
  purgedAt         DateTime? /// set by the purge cron once the R2 object is deleted
  archivedAt       DateTime? /// set when the file is moved to ARCHIVED status
  preArchiveStatus FileStatus? /// status before archiving — restored on un-archive

  versions     FileVersion[]
  activityLogs ActivityLog[]
  trashItem    TrashItem?
  tags         Tag[]         @relation("MediaFileTags")
  galleryFiles GalleryFile[]

  @@index([uploaderId])
  @@index([eventId])
  @@index([status])
  @@index([fileType])
  @@index([createdAt])
  @@index([uploaderId, eventId])
  @@index([status, fileType, createdAt])
}

model FileVersion {
  id            String   @id @default(cuid())
  mediaFileId   String
  versionNumber Int
  r2Key         String
  uploadedById  String
  createdAt     DateTime @default(now())

  mediaFile  MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation(fields: [uploadedById], references: [id])

  @@unique([mediaFileId, versionNumber])
}

// ─────────────────────────────────────────────
// Activity Log & Trash
// ─────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  userId      String?  /// null when the acting user's account has been deleted
  mediaFileId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id])
  mediaFile MediaFile? @relation(fields: [mediaFileId], references: [id], onDelete: SetNull)
  event     Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventId   String?
}

model TrashItem {
  id               String     @id @default(cuid())
  mediaFileId      String     @unique
  deletedById      String
  deletedAt        DateTime   @default(now())
  /// Set to deletedAt + 30 days on creation
  scheduledPurgeAt DateTime
  /// Status the file had before deletion — used to restore it correctly
  preDeleteStatus  FileStatus

  mediaFile MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)
  deletedBy User      @relation(fields: [deletedById], references: [id])
}

// ─────────────────────────────────────────────
// Tagging
// ─────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  files  MediaFile[] @relation("MediaFileTags")
  events Event[]     @relation("EventTags")
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

/// In-app notification record for a single user
model Notification {
  id        String   @id @default(cuid())
  userId    String
  /// e.g. FILE_UPLOADED | FILE_STATUS_CHANGED | TRANSFER_SENT | MESSAGE_SENT | SYSTEM
  type      String   @default("SYSTEM")
  /// Short heading shown bold in the bell panel
  title     String   @default("")
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

/// Web Push API subscription (VAPID)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Per-user per-category opt-in flags for push + email channels
model NotificationPreference {
  id       String  @id @default(cuid())
  userId   String
  /// e.g. UPLOAD_IN_FOLLOWED_FOLDER | FILE_STATUS_CHANGED | NEW_EVENT_CREATED | FILE_RESTORED | WEEKLY_DIGEST | FILE_PUBLISHED_ALERT | STORAGE_THRESHOLD_ALERT
  category String
  push     Boolean @default(true)
  email    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

/// A user following an event folder — determines upload push notifications
model FolderFollow {
  id      String @id @default(cuid())
  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

// ─────────────────────────────────────────────
// Password Reset
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Application Settings
// ─────────────────────────────────────────────

/// Global admin-configurable key/value settings.
/// Known keys: archive_threshold_months (default "6")
model AppSetting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// File Transfer System
// ─────────────────────────────────────────────
//
// QUALITY CONTRACT:
// -- Files in this system are NEVER recompressed, resized, or altered in any way.
// -- Checksums are computed on upload and verified on download to guarantee byte-for-byte integrity.
// -- The ZIP packaging uses STORE method (no compression) for already-compressed formats (jpg, mp4, png)
// -- and DEFLATE only for uncompressed formats (raw, tiff, bmp) to preserve maximum quality.

/// Admin sends a batch of files to a specific user for editing.
/// The recipient downloads them, edits them, then uploads edited versions back.
model Transfer {
  id              String         @id @default(cuid())
  senderId        String
  recipientId     String
  subject         String /// brief description, e.g. "Saturday Fellowship Photos for Editing"
  message         String? /// optional admin note to the recipient
  status          TransferStatus @default(PENDING)
  folderStructure Json? /// original folder structure if files were in subfolders
  r2Prefix        String /// R2 path prefix, e.g. "transfers/[transferId]/"
  totalFiles      Int
  totalSize       BigInt /// total bytes of all files combined
  isPinProtected  Boolean        @default(false) /// recipient must enter PIN before downloading
  pin             String?        /// bcrypt hash of 4–6 digit PIN; null = no PIN
  expiresAt       DateTime /// 30 days after COMPLETED, or 60 days after createdAt if never completed
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sender         User              @relation("sender", fields: [senderId], references: [id])
  recipient      User              @relation("recipient", fields: [recipientId], references: [id])
  files          TransferFile[]
  response       TransferResponse?
  linkedMessages Message[]

  @@index([senderId])
  @@index([recipientId])
  @@index([status])
  @@index([expiresAt])
}

/// Individual file sent as part of a Transfer.
model TransferFile {
  id           String   @id @default(cuid())
  transferId   String
  originalName String /// exact filename as uploaded by admin — never altered
  r2Key        String   @unique
  fileSize     BigInt
  mimeType     String
  folderPath   String? /// relative path if inside a subfolder, e.g. "Saturday/raw/"
  checksum     String /// MD5 or SHA-256 hash — verified on download to guarantee integrity
  createdAt    DateTime @default(now())

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

/// The recipient's reply: edited files uploaded back to the admin.
model TransferResponse {
  id                String   @id @default(cuid())
  transferId        String   @unique /// one response set per transfer
  uploadedById      String
  message           String? /// optional note from recipient back to admin
  r2Prefix          String /// R2 path for response files, e.g. "transfers/[transferId]/response/"
  totalFiles        Int
  totalSize         BigInt
  downloadedByAdmin Boolean  @default(false)
  createdAt         DateTime @default(now())

  transfer   Transfer               @relation(fields: [transferId], references: [id], onDelete: Cascade)
  uploadedBy User                   @relation("responseUploader", fields: [uploadedById], references: [id])
  files      TransferResponseFile[]

  @@index([uploadedById])
}

/// Individual edited file uploaded by the recipient as part of their TransferResponse.
model TransferResponseFile {
  id           String   @id @default(cuid())
  responseId   String
  originalName String
  r2Key        String   @unique
  fileSize     BigInt
  mimeType     String
  folderPath   String?
  checksum     String /// verified on admin download to ensure no corruption in transit
  createdAt    DateTime @default(now())

  response TransferResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([responseId])
}

// ─────────────────────────────────────────────
// Internal Messaging
// ─────────────────────────────────────────────

/// A direct or broadcast message sent by an Admin to one user or an entire role group.
model Message {
  id                   String          @id @default(cuid())
  senderId             String
  subject              String /// max 150 chars
  body                 String /// max 2000 chars
  priority             MessagePriority @default(NORMAL)
  broadcastRole        String? /// "UPLOADER" | "EDITOR" | "ALL" — if set, message was sent to the whole role group
  attachmentTransferId String? /// optionally link an existing Transfer to this message
  createdAt            DateTime        @default(now())

  sender             User               @relation("messageSender", fields: [senderId], references: [id])
  attachmentTransfer Transfer?          @relation(fields: [attachmentTransferId], references: [id], onDelete: SetNull)
  recipients         MessageRecipient[]

  @@index([senderId])
  @@index([createdAt])
  @@index([broadcastRole])
}

/// A single user's copy of a Message — tracks read state.
model MessageRecipient {
  id          String    @id @default(cuid())
  messageId   String
  recipientId String
  read        Boolean   @default(false)
  readAt      DateTime? /// timestamp when the user first opened the message
  createdAt   DateTime  @default(now())

  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient User    @relation("messageRecipient", fields: [recipientId], references: [id])

  @@unique([messageId, recipientId])
  @@index([recipientId, read])
  @@index([messageId])
}

// ─────────────────────────────────────────────
// Zara AI Assistant — Action Audit Log
// ─────────────────────────────────────────────
//
// Every action that Zara confirms and executes on behalf of a user is persisted here:
//  - PENDING   — confirmation card shown, waiting for user
//  - EXECUTED  — user confirmed, action ran successfully
//  - FAILED    — user confirmed but action threw an error
//  - ROLLED_BACK — admin reversed the action via the admin panel rollback tool
//
// Pre-action snapshots capture affected record state before mutation so rollbacks
// can restore the previous state accurately.

model ZaraActionLog {
  id                     String    @id @default(cuid())
  /// Tool name, e.g. "changeFileStatus", "unlockUserAccount"
  actionType             String
  /// ActionRiskLevel string: SAFE | MODERATE | SENSITIVE | HIGH | CRITICAL
  riskLevel              String
  requestedByUserId      String
  requestedByName        String
  /// When the user clicked "Confirm" on the confirmation card
  confirmedAt            DateTime
  /// When executePendingAction started running
  executedAt             DateTime?
  /// When the action fully completed (or failed)
  completedAt            DateTime?
  /// PENDING | EXECUTED | FAILED | ROLLED_BACK
  status                 String    @default("PENDING")
  /// Raw tool arguments passed to the action
  inputArgs              Json
  /// DB state before the action ran (for rollback). null = not captured or N/A
  preActionSnapshot      Json?
  /// Tool result object returned after execution
  postActionResult       Json?
  /// Structured data needed to reverse the action. null = action cannot be rolled back
  rollbackData           Json?
  /// If set, admin can trigger a rollback until this timestamp expires
  rollbackAvailableUntil DateTime?
  notes                  String?
  createdAt              DateTime  @default(now())

  requestedBy User @relation(fields: [requestedByUserId], references: [id])

  @@index([requestedByUserId])
  @@index([status])
  @@index([createdAt])
  @@index([actionType])
}

// ─────────────────────────────────────────────
// Zara AI Assistant — Session Usage Analytics
// ─────────────────────────────────────────────
//
// One record per chat session (from opening the widget to closing it).
// Written when the session ends or is flushed after inactivity.
// Powers the AI Assistant analytics tab in /admin/analytics.

model ZaraUsageLog {
  id               String    @id @default(cuid())
  userId           String
  sessionId        String /// groups messages from one chat session
  messageCount     Int /// how many user→Zara messages in this session
  toolsUsed        String[] /// list of tool names called during the session
  actionsProposed  Int /// how many action confirmation cards were shown
  actionsConfirmed Int /// how many were confirmed by the user
  actionsCancelled Int /// how many were cancelled by the user
  responseTimeMs   Int /// average Gemini response time (ms) for this session
  errorCount       Int /// errors during this session (API errors, tool failures)
  startedAt        DateTime
  endedAt          DateTime?
  pageContext      String /// which page/route the user was on when they opened the chat
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([startedAt])
  @@index([sessionId])
}

// ─────────────────────────────────────────────
// Zara AI Assistant — Conversation Training Logs
// ─────────────────────────────────────────────
//
// GDPR/Privacy compliance for ZaraConversationLog:
// ✓ PII removed before storage (names, emails, phone numbers)
// ✓ User IDs hashed — cannot reverse-identify individuals
// ✓ Users informed via first-use privacy notice
// ✓ Opt-out available at any time in Profile settings
// ✓ Opt-out triggers immediate retroactive deletion
// ✓ 90-day automatic retention limit
// ✓ Data stays in your own database — never sent to Google/Gemini
// ✓ Export available on user request
// ✓ Logs are metadata and sanitized content only — not raw conversations
//
// One record per message turn (USER or ASSISTANT).
// Two records per exchange: one USER turn, one ASSISTANT turn.

model ZaraConversationLog {
  id               String @id @default(cuid())
  sessionId        String /// same session ID as ZaraUsageLog — links for context
  anonymousUserId  String /// SHA256(userId) — NOT the real userId; can't trace back to person
  userRoleCategory String /// "UPLOADER" | "EDITOR" | "ADMIN" — role kept (useful); NOT username
  pageContext      String /// which page the user was on ("/upload", "/dashboard", etc.)
  messageIndex     Int /// position in conversation (1st message, 2nd, etc.)
  messageType      String /// "USER" | "ASSISTANT"

  /// USER message fields (populated when messageType = "USER"):
  userMessageCleaned String? /// sanitized user message with PII removed
  toolsTriggered     String[] /// which tools Zara called in response to this message
  intentCategory     String? /// auto-classified intent (HOW_TO, FIND_FILE, ERROR_REPORT, etc.)

  /// ASSISTANT message fields (populated when messageType = "ASSISTANT"):
  responseSummary String? /// first 200 chars of Zara's response
  responseTimeMs  Int? /// how long Gemini took (ms)
  usedToolData    Boolean? /// did this response include live database results?
  actionProposed  String? /// if an action was proposed, which tool name
  actionOutcome   String? /// CONFIRMED | CANCELLED | EXPIRED | null

  qualitySignals     Json? /// { wasAnswered, usedLiveData, actionWasProposed, actionWasConfirmed,
  ///   followUpMessageCount, sessionEndedAbruptly }
  createdAt          DateTime @default(now())
  retentionExpiresAt DateTime /// auto-delete after 90 days via daily cron

  @@index([sessionId])
  @@index([anonymousUserId])
  @@index([intentCategory])
  @@index([createdAt])
  @@index([retentionExpiresAt])
}

// ─────────────────────────────────────────────
// External Share Links
// ─────────────────────────────────────────────
//
// Allows Admin/Editor to generate a time-limited URL that gives
// an external person (no CMMS account needed) view/download access
// to a specific file, event folder, or transfer file set.
//
// Security properties:
//   - Token is a cuid() — random, unguessable
//   - Optional PIN is always stored as bcrypt hash — never plaintext
//   - Links expire automatically; Admin can force-revoke at any time
//   - Every access attempt is logged with IP + User-Agent

/// "FILE"    — shares a single MediaFile
/// "EVENT"   — shares all files in an Event (optionally filtered by subfolder)
/// "TRANSFER" — shares the files from a sent Transfer
model ShareLink {
  id           String   @id @default(cuid())
  token        String   @unique @default(cuid())
  createdById  String   /// FK → User
  linkType     String   /// "FILE" | "EVENT" | "TRANSFER"
  fileId       String?  /// FK → MediaFile  (linkType = FILE)
  eventId      String?  /// FK → Event      (linkType = EVENT)
  subfolderId  String?  /// FK → EventSubfolder (optional sub-scope for EVENT links)
  transferId   String?  /// FK → Transfer   (linkType = TRANSFER)
  title        String
  message      String?
  pinHash        String?  /// bcrypt hash of 4-digit PIN; null = no PIN required
  isPinProtected Boolean  @default(false) /// true when pinHash is set
  maxDownloads   Int?     /// null = unlimited
  downloadCount Int     @default(0)
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())

  createdBy User            @relation(fields: [createdById], references: [id])
  accesses  ShareLinkAccess[]

  @@index([token])
  @@index([createdById])
  @@index([expiresAt])
  @@index([isRevoked])
}

/// One row per access attempt (page view or file download) on a ShareLink.
model ShareLinkAccess {
  id          String   @id @default(cuid())
  shareLinkId String
  accessedAt  DateTime @default(now())
  ipAddress   String
  userAgent   String
  downloaded  Boolean  @default(false)

  shareLink ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  @@index([shareLinkId])
  @@index([accessedAt])
}

// ─────────────────────────────────────────────
// Public Gallery System
// ─────────────────────────────────────────────
//
// QUALITY CONTRACT:
// Three separate R2 keys per file — original is NEVER modified.
//   thumbnailKey  — small preview ~30KB for grid loading
//   previewKey    — medium quality ~200KB for lightbox
//   originalKey   — byte-for-byte identical to the source file

model PublicGallery {
  id                     String        @id @default(cuid())
  slug                   String        @unique
  title                  String
  description            String?
  coverImageKey          String?
  eventId                String?
  event                  Event?        @relation(fields: [eventId], references: [id])
  categoryName           String?
  year                   Int
  status                 GalleryStatus @default(DRAFT)
  createdById            String
  createdBy              User          @relation("GalleryCreatedBy", fields: [createdById], references: [id])
  publishedById          String?
  publishedBy            User?         @relation("GalleryPublishedBy", fields: [publishedById], references: [id])
  publishedAt            DateTime?
  isPasswordProtected    Boolean       @default(false)
  passwordHash           String?
  allowDownload          Boolean       @default(true)
  allowFullRes           Boolean       @default(true)
  requireNameForDownload Boolean       @default(false)
  totalPhotos            Int           @default(0)
  totalVideos            Int           @default(0)
  viewCount              Int           @default(0)
  downloadCount          Int           @default(0)
  r2Bucket               String        @default("christhood-gallery")
  sections               GallerySection[]
  files                  GalleryFile[]
  views                  GalleryView[]
  downloads              GalleryDownload[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  deletedAt              DateTime?
  deletedById            String?
  deletedBy              User?          @relation("GalleryDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  purgesAt               DateTime?
  preDeleteStatus        GalleryStatus?

  @@index([slug])
  @@index([status])
  @@index([year])
  @@index([eventId])
  @@index([createdById])
  @@index([deletedAt])
  @@index([purgesAt])
}

model GallerySection {
  id        String       @id @default(cuid())
  galleryId String
  gallery   PublicGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  title     String
  date      DateTime?
  sortOrder Int          @default(0)
  coverKey  String?
  photoCount Int         @default(0)
  files     GalleryFile[]
  createdAt DateTime     @default(now())

  @@index([galleryId])
}

model GalleryFile {
  id          String          @id @default(cuid())
  galleryId   String
  gallery     PublicGallery   @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  sectionId   String?
  section     GallerySection? @relation(fields: [sectionId], references: [id])
  mediaFileId String?
  mediaFile   MediaFile?      @relation(fields: [mediaFileId], references: [id])

  /// Small preview ~30KB for grid loading
  thumbnailKey String
  /// Medium quality ~200KB for lightbox
  previewKey   String
  /// ORIGINAL FILE: byte-for-byte identical to source — never modified
  originalKey  String

  originalName String
  fileType     GalleryFileType
  fileSize     BigInt
  width        Int?            /// image width in pixels (for masonry layout)
  height       Int?            /// image height in pixels (for masonry layout)
  sortOrder    Int             @default(0)
  isVisible    Boolean         @default(true)
  downloads    GalleryDownload[]
  faces        FaceEmbedding[]
  createdAt    DateTime        @default(now())

  @@index([galleryId])
  @@index([sectionId])
  @@index([mediaFileId])
  @@index([fileType])
}

model GalleryView {
  id         String       @id @default(cuid())
  galleryId  String
  gallery    PublicGallery @relation(fields: [galleryId], references: [id])
  viewedAt   DateTime     @default(now())
  /// MOBILE / DESKTOP / TABLET
  deviceType String?
  /// Derived from Cloudflare headers — raw IP is never stored
  country    String?

  @@index([galleryId])
  @@index([viewedAt])
}

model GalleryDownload {
  id           String       @id @default(cuid())
  galleryId    String
  gallery      PublicGallery @relation(fields: [galleryId], references: [id])
  fileId       String?
  file         GalleryFile? @relation(fields: [fileId], references: [id])
  /// SINGLE / ALL_ZIP / SELECTION
  downloadType String
  /// Only populated if requireNameForDownload is true
  visitorName  String?
  downloadedAt DateTime     @default(now())
  deviceType   String?

  @@index([galleryId])
  @@index([fileId])
  @@index([downloadedAt])
}

model FaceEmbedding {
  id          String      @id @default(cuid())
  fileId      String
  file        GalleryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  faceIndex   Int
  vector      Float[]
  boundingBox Json
  createdAt   DateTime    @default(now())

  @@index([fileId])
}

// ─────────────────────────────────────────────
// Public ShareLink Upload (no CMMS account required)
// ─────────────────────────────────────────────
//
// ISOLATION GUARANTEE:
//   - ZERO foreign keys to any other table in this schema
//   - Files stored exclusively under R2 prefix "public-shares/"
//   - No relationship to User, MediaFile, Transfer, or any CMMS model
//
// Flow:
//   1. POST /api/public-share/upload  → creates record (isReady=false) + returns presigned PUT URL
//   2. Client uploads directly to R2 via presigned URL
//   3. POST /api/public-share/[token]/confirm → sets isReady=true
//   4. Viewer hits /api/public-share/[token] → metadata + PIN gate
//   5. Viewer hits /api/public-share/[token]/download → presigned GET URL
//   6. Cron /api/cron/cleanup-public-shares  → deletes expired records + R2 objects
//
// Security:
//   - token = crypto.randomUUID() (128-bit random, unguessable)
//   - PIN bcrypt-hashed (never stored plaintext)
//   - 50 MB max upload size (enforced server-side)
//   - 7-day auto-expiry; isReady=false orphans purged after 2 hours
//   - 5 uploads per IP per hour (Upstash rate limit)
//   - uploaderIp stored for abuse tracing only

model PublicShareUpload {
  id            String   @id @default(cuid())
  /// crypto.randomUUID() — used as the public share token in the URL
  token         String   @unique
  /// R2 object key — always under "public-shares/{token}/{filename}"
  r2Key         String   @unique
  originalName  String
  fileSize      BigInt
  mimeType      String
  title         String?
  message       String?
  /// Optional recipient email address — used to send the download link
  recipientEmail String?
  /// bcrypt hash of optional 4–8 digit PIN; null = no PIN required
  pinHash       String?
  /// Expires exactly 7 days after creation
  expiresAt     DateTime
  downloadCount Int      @default(0)
  /// false until client POSTs /confirm after R2 upload completes
  isReady       Boolean  @default(false)
  /// Stored for abuse tracking only — never shown publicly
  uploaderIp    String
  createdAt     DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@index([isReady])
}

// ─────────────────────────────────────────────
// Photo Gallery Platform
// ─────────────────────────────────────────────
//
// Standalone Pixiset-like platform at gallery.cmmschristhood.org
// Completely decoupled from the CMMS User system — separate accounts.
//
// Structure: PhotoUser → PhotoCollection → PhotoAlbum → PhotoItem
// Auth:      Custom JWT (gp-session cookie) — email/password or Google OAuth
// Storage:   christhood-gallery R2 bucket, prefix "photo-platform/"
// Payments:  Paystack (M-Pesa + cards) + Stripe

enum PhotoPlanTier {
  FREE    /// 5 GB storage included
  PREMIUM /// paid plan — storage limit per PhotoPlan.storageLimitBytes
}

enum PhotoAlbumVisibility {
  PUBLIC   /// anyone with the link can view
  PASSWORD /// requires password to view
  PRIVATE  /// owner only
}

/// A gallery platform user — completely separate from CMMS User
model PhotoUser {
  id                String        @id @default(cuid())
  username          String        @unique  /// URL slug — e.g., "christhood"
  displayName       String
  email             String        @unique
  passwordHash      String?       /// null for Google-only accounts
  googleId          String?       @unique  /// Google OAuth subject
  avatarUrl         String?
  bio               String?
  isSuperAdmin      Boolean       @default(false)  /// only danielmwaliliofficial@gmail.com
  planTier          PhotoPlanTier @default(FREE)
  storageUsedBytes  BigInt        @default(0)
  storageLimitBytes BigInt        @default(5368709120) /// 5 GB free tier
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  collections   PhotoCollection[]
  subscriptions PhotoSubscription[]

  @@index([email])
  @@index([username])
  @@index([googleId])
}

/// Top-level folder. e.g., "Saturday Fellowships", "Missions"
model PhotoCollection {
  id          String   @id @default(cuid())
  slug        String
  title       String
  description String?
  coverKey    String?  /// R2 key for cover image
  ownerId     String
  owner       PhotoUser @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0)
  isVisible   Boolean  @default(true)
  albums      PhotoAlbum[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerId, slug])
  @@index([ownerId])
}

/// Album within a collection. e.g., "March 29, 2026"
model PhotoAlbum {
  id              String               @id @default(cuid())
  slug            String
  title           String
  description     String?
  coverKey        String?              /// R2 key for cover photo
  collectionId    String
  collection      PhotoCollection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  visibility      PhotoAlbumVisibility @default(PUBLIC)
  passwordHash    String?              /// bcrypt hash — only when visibility = PASSWORD
  allowDownload   Boolean              @default(true)
  sortOrder       Int                  @default(0)
  photoCount      Int                  @default(0)
  totalSizeBytes  BigInt               @default(0)
  viewCount       Int                  @default(0)
  items           PhotoItem[]
  shareTokens     PhotoShareToken[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([collectionId, slug])
  @@index([collectionId])
}

/// A single photo (or video) inside an album
model PhotoItem {
  id            String     @id @default(cuid())
  albumId       String
  album         PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  thumbnailKey  String     /// ~30 KB JPEG for grid
  previewKey    String     /// ~200 KB JPEG for lightbox
  originalKey   String     /// byte-for-byte original (never modified)
  originalName  String
  mimeType      String
  fileSizeBytes BigInt
  width         Int?
  height        Int?
  sortOrder     Int        @default(0)
  caption       String?
  createdAt     DateTime   @default(now())

  @@index([albumId])
}

/// A shareable link token for an album
model PhotoShareToken {
  id            String     @id @default(cuid())
  token         String     @unique @default(cuid())
  albumId       String
  album         PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  label         String?    /// e.g., "WhatsApp group link"
  allowDownload Boolean    @default(true)
  passwordHash  String?    /// optional extra password layer on this share link
  expiresAt     DateTime?
  viewCount     Int        @default(0)
  createdAt     DateTime   @default(now())

  @@index([token])
  @@index([albumId])
}

/// Subscription plan definition
model PhotoPlan {
  id                String        @id @default(cuid())
  name              String        @unique
  tier              PhotoPlanTier
  priceKes          Int           /// price in Kenyan Shillings (0 = free)
  priceUsdCents     Int           /// price in USD cents (0 = free)
  storageLimitBytes BigInt
  description       String?
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())

  subscriptions PhotoSubscription[]
}

/// A user's active subscription
model PhotoSubscription {
  id                 String     @id @default(cuid())
  userId             String
  user               PhotoUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId             String
  plan               PhotoPlan  @relation(fields: [planId], references: [id])
  paystackRef        String?    /// Paystack transaction reference
  stripeRef          String?    /// Stripe payment intent ID
  status             String     @default("ACTIVE") /// ACTIVE | CANCELLED | EXPIRED
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([userId])
  @@index([status])
}
